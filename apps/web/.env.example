# zenstory - Frontend Environment Variables
# Copy this file to .env.local and configure as needed

# ============================================
# Authentication Configuration
# ============================================

# Enable/disable public registration (default: true)
# Set to 'false' to hide registration page and links
VITE_REGISTRATION_ENABLED=true

# Enable/disable forgot password feature (default: false)
VITE_FORGOT_PASSWORD_ENABLED=false

# Registration invite code policy (UI behavior)
# false (default): invite code required in form
# true: invite code optional in form
VITE_INVITE_CODE_OPTIONAL=false

# ============================================
# OAuth Providers (Third-party Login)
# ============================================

# Google OAuth
VITE_GOOGLE_OAUTH_ENABLED=true
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Apple OAuth (Sign in with Apple)
VITE_APPLE_OAUTH_ENABLED=false
VITE_APPLE_CLIENT_ID=

# ============================================
# API Configuration
# ============================================

# Backend API base URL (default: http://localhost:8000)
# Development: http://localhost:8000
# Production: https://api.yourdomain.com
# VITE_API_BASE_URL=http://localhost:8000

# ============================================
# Analytics (Optional)
# ============================================

# Vercel Analytics (automatic if enabled)
# Google Analytics
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry for error tracking (optional)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/12345

# PostHog product analytics and frontend error tracking
VITE_POSTHOG_ENABLED=false
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ============================================
# Feature Flags
# ============================================

# Enable/disable specific features (optional)
# VITE_ENABLE_VOICE_INPUT=false
# VITE_ENABLE_EXPORT=true
# Materials library "coming soon" switch (set true to show placeholder UI)
VITE_MATERIALS_COMING_SOON=false
# Points panel switch in settings dialog (set false to temporarily hide panel)
VITE_POINTS_PANEL_ENABLED=true
