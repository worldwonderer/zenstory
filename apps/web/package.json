{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:typecheck": "tsc -b && vite build",
    "lint:tokens": "node ../../scripts/quality/check-web-css-token-vars.mjs",
    "lint:i18n-keys": "node ../../scripts/quality/check-i18n-defaultvalue-keys.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "NODE_OPTIONS='--max-old-space-size=8192' vitest",
    "test:run": "NODE_OPTIONS='--max-old-space-size=8192' vitest run",
    "test:coverage": "NODE_OPTIONS='--max-old-space-size=8192' vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --project=chromium-headed",
    "test:e2e:mocked": "playwright test --project=chromium-mocked",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:all-browsers": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:e2e:local": "pnpm --dir ../.. e2e:zenstory:local",
    "test:e2e:local:default": "pnpm --dir ../.. e2e:zenstory:local:default",
    "test:e2e:local:nightly": "pnpm --dir ../.. e2e:zenstory:local:nightly",
    "test:e2e:local:release": "pnpm --dir ../.. e2e:zenstory:local:release",
    "test:e2e:local:full": "pnpm --dir ../.. e2e:zenstory:local:full",
    "test:smoke": "playwright test smoke.spec.ts --project=chromium",
    "test:ci-local": "act -j e2e-test",
    "test:ci-local:all": "act"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-virtual": "^3.13.18",
    "@tiptap/extension-image": "^3.15.3",
    "@tiptap/extension-link": "^3.15.3",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "@types/diff-match-patch": "^1.0.36",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "diff-match-patch": "^1.0.5",
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "immer": "^10.1.4",
    "lucide-react": "^0.562.0",
    "posthog-js": "^1.364.1",
    "react": "^19.2.0",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.3",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.3.2",
    "react-router-dom": "^7.12.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "use-immer": "^0.11.0",
    "web-vitals": "^5.1.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.0",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^1.2.0",
    "@vitest/ui": "^1.2.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "happy-dom": "^13.3.8",
    "jsdom": "^24.0.0",
    "msw": "^2.1.0",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-sitemap": "^0.8.2",
    "vitest": "^1.2.0"
  }
}
