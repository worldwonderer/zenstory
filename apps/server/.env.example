# ============================================
# Quick Start — set ONE API key and you're done
# ============================================

# LLM Provider (required — pick one)
# DeepSeek: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key

# Or use Anthropic directly:
# ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================
# That's it for local development!
#
# Below are OPTIONAL settings with sensible
# defaults. Override only if you need to.
# ============================================

# --- LLM Fine-tuning (optional) ---
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Agent model / thinking (optional, defaults in agent/llm/anthropic_client.py)
# AGENT_MODEL=deepseek-v4-flash
# AGENT_MAX_TOKENS=64000
# AGENT_TEMPERATURE=1.0
# AGENT_THINKING_ENABLED=true
# AGENT_THINKING_BUDGET_TOKENS=10000

# Router (optional, latency-sensitive)
# AGENT_ROUTER_MODEL=deepseek-v4-flash
# AGENT_ROUTER_MAX_TOKENS=4096

# --- Database (optional) ---
# Defaults to SQLite for local dev; set for PostgreSQL in production
# DATABASE_URL=postgresql://user:password@host:port/database

# --- Auth (optional) ---
# JWT_SECRET_KEY is auto-generated in development.
# Must be set explicitly (min 32 chars) in production/staging.
# JWT_SECRET_KEY=
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS (optional) ---
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- General (optional) ---
# LOG_LEVEL=INFO
# APP_NAME=zenstory
# APP_VERSION=1.0.0
# CHROMA_PERSIST_DIR=./chroma_data

# ============================================
# Advanced / Production-only
# ============================================

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# FRONTEND_URL=https://zenstory.ai

# Zhipu Embeddings (for vector search)
# ZHIPU_EMBEDDINGS_API_KEY=
# ZHIPU_EMBEDDINGS_MODEL=embedding-3

# Tencent ASR (voice input)
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=

# Rate Limiting
# AUTH_RATE_LIMIT_ENABLED=true
# RATE_LIMIT_BACKEND=auto

# Redemption Codes
# REDEMPTION_CODE_HMAC_SECRET=
