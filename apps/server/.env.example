# ============================================
# Quick Start — writing agent uses DeepSeek only
# ============================================

# Required for the writing agent.
# The model is fixed in code to deepseek-v4-flash.
DEEPSEEK_API_KEY=your-deepseek-api-key

# ============================================
# Optional settings with sensible defaults
# ============================================

# --- Writing Agent runtime (optional) ---
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# AGENT_OPENAI_AGENTS_MAX_OUTPUT_TOKENS=64000
# AGENT_ROUTER_STRATEGY=llm
# AGENT_ENABLE_GRAPH_AUTO_REVIEW=true

# --- Database (optional) ---
# Defaults to SQLite for local dev; set for PostgreSQL in production
# DATABASE_URL=postgresql://user:password@host:port/database

# --- Auth (optional) ---
# JWT_SECRET_KEY is auto-generated in development.
# Must be set explicitly (min 32 chars) in production/staging.
# JWT_SECRET_KEY=
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS (optional) ---
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- General (optional) ---
# LOG_LEVEL=INFO
# APP_NAME=zenstory
# APP_VERSION=1.0.0
# CHROMA_PERSIST_DIR=./chroma_data

# ============================================
# Advanced / Production-only
# ============================================

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# FRONTEND_URL=https://zenstory.ai

# Zhipu Embeddings (for vector search)
# ZHIPU_EMBEDDINGS_API_KEY=
# ZHIPU_EMBEDDINGS_MODEL=embedding-3

# Tencent ASR (voice input)
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=

# Rate Limiting
# AUTH_RATE_LIMIT_ENABLED=true
# RATE_LIMIT_BACKEND=auto

# Redemption Codes
# REDEMPTION_CODE_HMAC_SECRET=
