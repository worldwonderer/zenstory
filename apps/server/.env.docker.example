# zenstory server - Docker environment template
# Copy to: apps/server/.env.docker

# ============================================
# Required for the writing agent — DeepSeek only
# ============================================
# The model is fixed in code to deepseek-v4-flash.
DEEPSEEK_API_KEY=your-deepseek-api-key

# ============================================
# Service URLs (inside docker network)
# ============================================
DATABASE_URL=postgresql://user:password@postgres:5432/zenstory
REDIS_URL=redis://redis:6379/0

# ============================================
# General (sensible defaults, override if needed)
# ============================================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# JWT secret — must be set in production (min 32 chars)
JWT_SECRET_KEY=change-me-to-a-strong-secret-at-least-32-chars
